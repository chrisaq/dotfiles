#!/bin/bash
#:usage: cq_pass-add
#:no-args: true
#:desc: Create a new gopass entry via rofi prompts.

shopt -s nullglob globstar

pexit() {
    echo "$1"
    exit 1
}

run_gopass_insert() {
    local entry=$1

    if [[ ${TERM_PROGRAM:-} == ghostty ]]; then
        gopass insert "$entry"
    else
        ghostty -e gopass insert "$entry"
    fi
}

STORE=${PASSWORD_STORE_DIR:-~/Sync/Password-Store}

FOLDER=$(
    find "$STORE" -type d -not -path '*/\.*' -printf "%d %P\n" |
        sort -n |
        cut -d ' ' -f2- |
        rofi -dmenu -i -p Folder
)
[[ -n $FOLDER ]] || pexit "no folder"

DOMAIN=$(rofi -dmenu -p Domain)
[[ -n $DOMAIN ]] || pexit "no domain"

USER=$(rofi -dmenu -p User/email)
[[ -n $USER ]] || pexit "no user"

PPASS="${FOLDER}/${DOMAIN}/${USER}"

OK=$(printf 'yes\nno\n' | rofi -dmenu -p "Create ${PPASS} ?")

if [[ $OK == yes ]]; then
    echo "insert $PPASS"
    run_gopass_insert "$PPASS"
else
    echo "no insert"
fi
